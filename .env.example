# ──────────────────────────────────────────────
# LabTrack — Environment Configuration Template
# Copy this file to .env and fill in your values
# ──────────────────────────────────────────────

# Django core
SECRET_KEY=change-me-to-a-long-random-string-at-least-50-chars
DEBUG=False
ALLOWED_HOSTS=localhost,127.0.0.1

# Database (PostgreSQL)
# When DB_HOST is set, PostgreSQL is used. Leave blank to use SQLite (dev only).
DB_NAME=labtrack
DB_USER=labtrack
DB_PASSWORD=changeme
DB_HOST=db
DB_PORT=5432

# Redis (used by Celery for background tasks)
REDIS_URL=redis://redis:6379/0

# Email
# When EMAIL_HOST_USER and EMAIL_HOST_PASSWORD are both set, real SMTP is used.
# Leave blank to print emails to the console (useful for development).
EMAIL_HOST=smtp.gmail.com
EMAIL_PORT=587
EMAIL_HOST_USER=
EMAIL_HOST_PASSWORD=
DEFAULT_FROM_EMAIL=LabTrack <noreply@yourdomain.com>

# Full public URL of your deployment — used in email notification links.
SITE_URL=https://yourdomain.com

# Gunicorn tuning (optional)
GUNICORN_WORKERS=3
GUNICORN_TIMEOUT=120
GUNICORN_LOG_LEVEL=info

# Nginx port (optional, default 80)
NGINX_PORT=80

# Django log level (optional, default INFO)
DJANGO_LOG_LEVEL=INFO
